# Standard: Git soll Textdateien normalisieren
* text=auto

# Shell/Docker/Linux-relevante Dateien immer mit LF speichern
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Python/Django
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# Windows-Skripte dürfen CRLF behalten
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binärdateien nicht verändern
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
