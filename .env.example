# IMAGE_TAG=latest
# DEBUG=1
SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1]
# PUID=1000
# PGID=1000
# WEB_HOST=0.0.0.0
# WEB_PORT=8000
# WEB_CONCURRENCY=3
# APP_PATH=
# LANGUAGE_CODE=de-de
# TZ=Europe/Berlin
# SQLITE_PATH=/data/db.sqlite3
# AI_ASSISTANT_ENABLED=false
# AI_ASSISTANT_PROVIDER=disabled
# AI_ASSISTANT_MODEL=
# AI_ASSISTANT_BASE_URL=
# AI_ASSISTANT_TIMEOUT_SECONDS=10
# EMAIL_HOST=localhost
# EMAIL_PORT=25
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=0
# DEFAULT_FROM_EMAIL=webmaster@localhost
# LOGIN_ENABLED=1

# Reverse-Proxy-/HTTPS-Betrieb (siehe README, Abschnitt Konfiguration):
# Vollstaendige Origins fuer den CSRF-Origin-Check hinter einem HTTPS-Proxy.
# CSRF_TRUSTED_ORIGINS=https://steuer.example.de
# Nur setzen, wenn der Proxy X-Forwarded-Proto zuverlaessig setzt.
# USE_X_FORWARDED_PROTO=1
# Session-/CSRF-Cookies nur ueber HTTPS ausliefern.
# COOKIES_SECURE=1
# HSTS erst aktivieren, wenn die Domain dauerhaft per HTTPS laeuft.
# SECURE_HSTS_SECONDS=0
# SECURE_HSTS_INCLUDE_SUBDOMAINS=0
# SECURE_HSTS_PRELOAD=0
# SECURE_SSL_REDIRECT=0
