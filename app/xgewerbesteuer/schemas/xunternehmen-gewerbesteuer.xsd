                  <xs:documentation>Optionale(r) Erläuterungstext(e) der steuererhebenden Kommune in beliebiger Anzahl.</xs:documentation>
               </xs:annotation>
            </xs:element>
         </xs:sequence>
      </xs:complexType>
   </xs:element>
